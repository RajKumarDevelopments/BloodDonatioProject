.searchbar-input.sc-ion-searchbar-md {
  -webkit-padding-start: 3.4375rem;
  padding-inline-start: 3.4375rem;
  -webkit-padding-end: 3.4375rem;
  padding-inline-end: 3.4375rem;
  padding-top: 0.375rem;
  padding-bottom: 0.375rem;
  background-position: left 8px center;
  height: auto;
  font-size: 1rem;
  font-weight: 400;
  line-height: 30px;
  border-radius: 20px !important;
}

.red-button {
  background: red;
  background-activated: darkred;
  background-focused: red;
  background-hover: red;
  color: white;
  padding: 12px;
  width: 100%;
  //RambabuP
  font-size: 14px;
  //=============
}

ion-footer {
  padding: 10px
}
:host .ionicon {
  //stroke: currentcolor;
  display: none;
}
ion-button {
  border-radius: 20px !important
}

button {
  border-radius: 20px !important;
  background-activated: darkred;
  background-focused: red;
  background-hover: red;
  color: white;
  padding: 10px;
  width: 100%;
}

:host {
  display: flex;
  position: relative;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  height: 200px;
  font-size: 17px !important;
  text-align: center;
}

ion-modal > .ion-page {
  position: relative;
  contain: layout style;
  height: auto !important;
}

body, p, div, span, ion-content, ion-title, ion-row, ion-col, ion-label, ion-list, ion-note, ion-picker {
  font-family: Arial !important;
  font-size: 13px !important;
}

html.md {
  --ion-default-font: Arial !important;
}

button {
  /*font-family: Arial !important;*/
}

h1, h2, h3, h4, h5, h6, ion-card {
  /*font-family: Arial !important;*/
}

ion-content {
  padding: 10px
}

.item.sc-ion-label-md-h, .item .sc-ion-label-md-h {
  --color: initial;
  display: block;
  color: var(--color);
  font-family: 'Arial !important';
  font-size: 15px;
  text-overflow: ellipsis;
  -webkit-box-sizing: border-box;
  box-sizing: border-box;
}

ion-header ion-toolbar:first-of-type {
  padding-top: var(--ion-safe-area-top, 0);
  --background: white;
  --color: black;
  box-shadow: none;
  margin-bottom: -5%;
}

ion-title {
  text-align: center;
  padding: 15px;
}

ion-toolbar ion-icon {
  padding: 16px;
  font-size: 20px;
}

.searchbar-search-icon.sc-ion-searchbar-md {
  top: 12px;
  width: 1.3125rem;
  height: 1.3125rem;
  padding: 0;
}

:host(.button-solid) {
  --background: #9b160c !important;
  --color: var(--ion-color-primary-contrast, #fff);
}

.footer-md {
  -webkit-box-shadow: 0 2px 4px -1px rgba(0, 0, 0, 0.2), 0 4px 5px 0 rgba(0, 0, 0, 0.14), 0 1px 10px 0 rgba(0, 0, 0, 0.12);
  box-shadow: none;
}

.header-md {
  -webkit-box-shadow: 0 2px 4px -1px rgba(0, 0, 0, 0.2), 0 4px 5px 0 rgba(0, 0, 0, 0.14), 0 1px 10px 0 rgba(0, 0, 0, 0.12);
  box-shadow: none;
  /*border-bottom: 1px solid #d3d3d3a6;*/
}

.input-fill-outline.sc-ion-input-md-h {
  --border-color: var(--ion-color-step-300, var(--ion-background-color-step-300, #b3b3b3));
  --border-radius: 40px !important;
  --padding-start: 16px;
  --padding-end: 14px;
  /*min-height: 48px;*/
}

/*.input-label-placement-floating.sc-ion-input-md-h, .input-label-placement-stacked.sc-ion-input-md-h {
  min-height: 35px;
}*/

.input-fill-outline.sc-ion-input-md-h .input-outline-container.sc-ion-input-md {
  left: 0px !important;
  right: 0;
  /*top: 9px !important;*/
  bottom: 0;
  display: flex;
  position: absolute;
  width: 100% !important;
  height: 87% !important;
}

input {
  border: 1px solid gray;
  padding: 5px;
  border-radius: 50px;
  width: 90%
}

ion-headder ion-title {
  text-transform: uppercase !important;
}

.profile {
  /*font-family: Arial !important;*/
}

.imgg {
  border-radius: 50px !important;
}

.namee {
  font-size: 13px !important;
  color: gray !important;
}

.footer_content {
  height: 10vh;
}

.p5 {
  padding: 5%;
}

.terms {
  /*padding: 2px 19px 0px 26px;*/
  padding: 5% 5% 5% 8%;
}

.privacy {
  padding: 14px 36px 1px 0px;
  margin-top: 7px;
  //padding: 2px 19px 0px 26px;
}

.item-content p {
  color: #abaeb3 !important;
  font-weight: normal;
  font-size: 10px
}

.swiper-pagination {
  transform: translate3d(0px, 10px, 0px) !important;
}

.tabs_title {
  font-size: 10px !important;
}

.p1 {
  padding-left: 4% !important;
  margin-top: 0.5rem;
}

.m1 {
  margin-left: 2% !important;
}

.m2 {
  margin-left: -2% !important;
}

.m3 {
  margin-left: 2.5rem !important;
}
/*:host(.select-label-placement-floating), :host(.select-label-placement-stacked) {
  min-height: 35px;
}*/

.custom-modal .modal-wrapper {
  max-height: 40% !important;
  --height: 40%;
}

.custom-modal .box {
  height: auto;
  overflow-y: auto;
  padding: 5%;
}

/*.custom-modal .modal-wrapper {
  --width: 100%;
  --height: auto;
  --max-height: 60%; 
  --min-height: auto;
  --border-radius: 1rem 1rem 0 0; 
  --background: white;
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}*/
.custom-modal .modal-wrapper {
  --width: 100%;
  --height: 100%;
  --border-radius: 1rem 1rem 0 0; /* Rounded corners for the top */
  --background: white;
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.scroll-content {
  height: 100%;
  overflow-y: auto;
  padding: 5%;
}
ion-accordion.accordion-animated > [slot=header] .ion-accordion-toggle-icon {
  transition: 300ms transform cubic-bezier(0.25, 0.8, 0.5, 1);
  display: none;
}


:root {
  --ion-background-color: #ffffff; /* Light background color */
  --ion-text-color: black; /* Light text color */
  /* Add other light mode variables as needed */
}
.accordionheader {
  background: white;
  padding: 0 3%;
  border-bottom: 1px solid #9b9b9b;
}
.content {
  background: white;
  margin: 2%;
  padding: 10px;
  border-top: none;
  box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
}
input,text,textarea{
  background: white;
}
.card {
  background: white;
}
div {
}
ion-col {
  //background: white;
}
.captial {
  text-transform: capitalize;
}



.common_card {
  background-color: white;
  border-radius: 50px;
  margin: 5% 0% -3% 5%;
  box-shadow: rgba(0, 0, 0, 0.07) 0px 1px 1px, rgba(0, 0, 0, 0.07) 0px 2px 2px, rgba(0, 0, 0, 0.07) 0px 4px 4px, rgba(0, 0, 0, 0.07) 0px 8px 8px, rgba(0, 0, 0, 0.07) 0px 16px 16px;
  width: 90%;
  height: 60px;
}
.card-content {
  display: flex;
  align-items: center;
  padding-bottom: 5px;
  padding-top: 5px;
}
.card_icon {
  font-size: 21px;
  color: white;
  // margin: -4% 3% -3% -2%;
  margin: -4% 4% -3% 3%;
  font-weight: bold;
  width: 65px;
  margin-left: -11px;
}

.card_icon1 {
  margin: 0% 4% 1% 4%;
  font-size: 26px;
  color: #e31515;
  font-weight: bold;
  width: 28px;
}

.card_icon2 {
  font-size: 21px;
  color: white;
  margin: 0% 4% 1% 3%;
  font-weight: bold;
  width: 28px;
}
.highlight {
  color: #000000bd;
  font-weight: bold;
  /*font-family: Arial !important;*/
  font-size: 14px;
}

.highlight1 {
  color: #000000bd;
  font-weight: bold;
  /*font-family: Arial !important;*/
  font-size: 14px;
  margin-left: -11px;
}
 
.tabs_title {
  font-size: 10px !important;
}

.ficons {
  width: 40% !important;
  margin: 8% 28% !important;
}
.ficons_white {
  width: 55% !important;
  margin: 11% 22% !important;
}
.notif_icon {
  padding: 12px;
  width: 90%;
  margin: 5% 0%;
}

.searchbar-clear-button.sc-ion-searchbar-md {
  inset-inline-end: -8rem !important;
}

/*==========cards==============*/

.cards {
  box-shadow: rgba(9, 30, 66, 0.25) 0px 4px 8px -2px, rgba(9, 30, 66, 0.08) 0px 0px 0px 1px;
  background-color: white;
  border-radius: 50px;
  border: 1px solid transparent;
  margin: 0% 4% 0% 4%;
  padding: 1.5% 0%;
}

.cards p {
  margin: 0%;
  text-align: left !important;
}

.icon_img {
  align-content: center;
  text-align: center;
}

.icon_imgs {
  width: 60%;
}

.gray {
  color: #b9bcc5 !important;
}
.head1 {
  color: rgb(65, 67, 88);
  font-weight: 700;
  font-size: 15px !important;
}
/*============footer===================*/
.footer_card {
  background-color: #ec1c2c;
  color: white;
  border-radius: 50px;
  box-shadow: rgba(60, 64, 67, 0.3) 0px 1px 2px 0px, rgba(60, 64, 67, 0.15) 0px 1px 3px 1px;
  width: 100%;
  padding: 2% 0%;
}
.footer_card img {
  width: 50%;
}
.footer_label {
  color: white !important;
  text-align: left;
  font-size: 14px !important
}
.footer_label_col {
  align-content: center;
}

.footer_card p {
  margin: 0%;
  text-align: left !important;
  color: #ffffffa8 !important;
}

.row_footer {
  padding: 0% 5% 0% 5%;
}
.footer_card1 {
  background-color: #ec1c2c;
  color: white;
  border-radius: 50px;
  box-shadow: rgba(60, 64, 67, 0.3) 0px 1px 2px 0px, rgba(60, 64, 67, 0.15) 0px 1px 3px 1px;
  width: 100%;
  padding: 3% 0%;
}
.footer_card1 img {
  width: 50%;
}
