  providers: [LocalNotifications,PhotoViewer,GooglePlaceModule,LaunchNavigator,InAppBrowser, AndroidFullScreen, SocialSharing, DatePipe, AndroidPermissions, LocationAccuracy, { provide: RouteReuseStrategy, useClass: IonicRouteStrategy }],
  bootstrap: [AppComponent],
